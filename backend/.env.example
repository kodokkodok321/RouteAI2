# Database
# For Railway: copy from Railway PostgreSQL service → Variables → DATABASE_URL
DATABASE_URL="postgresql://user:password@localhost:5432/routeai?schema=public"

# Server
PORT=5000
NODE_ENV=development

# CORS — set to your Vercel frontend URL in production
# Example: https://routeai.vercel.app
FRONTEND_URL=http://localhost:3000

# Optional: Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
